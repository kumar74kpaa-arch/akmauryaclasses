generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactEnquiry {
  id          String   @id @default(cuid())
  studentName String
  parentName  String?
  phone       String
  class       String?
  course      String
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DemoBooking {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  class     String?
  subject   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
